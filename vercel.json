{
  "version": 2,
  "buildCommand": "echo 'Skipping frontend build'",
  "installCommand": "echo 'Skipping frontend install'",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(admin|assets|files|front|images|vendor|languages|print|cgi-bin)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/245x53.png",
      "dest": "/public/245x53.png"
    },
    {
      "src": "/product-csv-format.csv",
      "dest": "/public/product-csv-format.csv"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
